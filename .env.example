# candango-website — build-time public vars (copy to .env; PUBLIC_* are exposed to the browser).
# Local dev falls back to localhost if unset.
PUBLIC_APP_URL=https://app.candango.bsbtechub.com
PUBLIC_API_URL=https://app.candango.bsbtechub.com/v1
# Optional: overrides the canonical site URL used by astro.config.mjs
# SITE=https://candango.bsbtechub.com
