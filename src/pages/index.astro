---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Shot from '../components/Shot.astro';
import Carousel from '../components/Carousel.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:3000';

// Email/calendar spotlight slider.
const emailSlides = [
  { label: 'Gmail in Candango', src: '/shots/email.png', alt: 'Synced Gmail inbox inside Candango', caption: 'Email Sync' },
  { label: 'Google Calendar', src: '/shots/calendar.png', alt: 'Google Calendar activities inside Candango', caption: 'Calendar Sync' },
  { label: 'The deal screen', src: '/shots/deal.png', alt: 'A deal with its full activity timeline', caption: 'Easy Access' },
];

const features = [
  { title: 'Visual pipeline', body: 'See your whole pipeline at a glance, with a live forecast.', icon: 'M4 6h16M4 12h10M4 18h7' },
  { title: 'Sync email & calendar', body: 'Gmail and Google Calendar, right inside Candango.', icon: 'M3 7l9 6 9-6M4 5h16v14H4z' },
  { title: 'Estimates & invoices', body: 'Create and manage them, synced with QuickBooks.', icon: 'M9 7h6M9 11h6M9 15h4M5 4h14v16H5z' },
  { title: 'Reports that matter', body: 'Pipeline health and win rates at a glance.', icon: 'M5 21V9M12 21V4M19 21v-7' },
];

const steps = [
  { n: '01', title: 'Set up your pipeline', body: 'Add your opportunities and organize them your way — in minutes.' },
  { n: '02', title: 'Work it all in one place', body: 'Email, calendar, contacts, and notes — side by side, no tab-hopping.' },
  { n: '03', title: 'Close and invoice', body: 'Win the sale and create your estimates and invoices in a click.' },
];

const gallery = [
  { src: '/shots/dashboard.png', alt: 'Dashboard — open deals, weighted pipeline, and won this month' },
  { src: '/shots/reports.png', alt: 'Reports — pipeline value by stage and by sales rep' },
  { src: '/shots/contacts.png', alt: 'People and companies, linked to their deals' },
  { src: '/shots/integrations.png', alt: 'Optional Google and QuickBooks integrations' },
];

const openPlatform = [
  { title: 'A REST API for everything', body: 'A clean, documented REST API with managed keys — build integrations, scripts, and internal tools right on your data.', icon: 'm16 18 6-6-6-6M8 6l-6 6 6 6' },
  { title: 'Real-time webhooks', body: 'Get notified the instant something changes and push events straight into the tools your team already runs on.', icon: 'M22 12h-4l-3 9L9 3l-3 9H2' },
  { title: 'Custom fields', body: 'Shape the data to your business — add the fields you actually need across contacts, companies, and your pipeline.', icon: 'M4 21v-7M4 10V3M12 21v-9M12 8V3M20 21v-5M20 12V3M1 14h6M9 8h6M17 16h6' },
];

const faqs = [
  { q: 'Do I need a credit card to start?', a: 'No. Every workspace starts with a 7-day free trial — add a card only when you’re ready to keep going.' },
  { q: 'How does pricing work?', a: 'A flat $30 per active user each month. Deactivated members don’t count.' },
  { q: 'How do email and calendar work?', a: 'Connect Google once to read and send email and see your calendar inside Candango. Your conversations stay in context, and meetings sync both ways with Google Calendar.' },
  { q: 'How does QuickBooks work?', a: 'Connect QuickBooks Online to create and manage estimates and invoices in Candango, organized by account.' },
  { q: 'Can I connect Candango to my other tools?', a: 'Yes. There\'s a documented REST API with managed keys, outbound webhooks for real-time events, and custom fields to match your data — so Candango fits your stack instead of replacing it.' },
];
---

<Base>
  <Nav />

  <!-- HERO (dark) -->
  <section class="relative overflow-hidden bg-ink text-white">
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(1200px 520px at 72% -12%, rgba(217,85,44,.20), transparent);"
    >
    </div>
    <div class="container-site relative py-24 md:py-32">
      <p class="eyebrow text-terra-300">All in one place</p>
      <h1 class="mt-3 max-w-[15ch] text-display-xl font-extrabold">Your whole sales workflow, in one place.</h1>
      <p class="mt-5 max-w-[44ch] text-lead text-sand-200">
        The simple, fast CRM that keeps your pipeline moving and your team focused on selling.
      </p>
      <div class="mt-8 flex flex-wrap gap-3.5">
        <a href={`${appUrl}/signup`} class="btn btn-primary">Start free</a>
        <a href="#features" class="btn btn-on-dark">See how it works</a>
      </div>
      <p class="mt-4 text-sm text-ink-soft">Free for 7 days. No credit card.</p>

      <Shot src="/shots/pipeline.png" alt="Candango pipeline board with deals across stages" class="mt-14" />
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="bg-sand-cream py-24 md:py-28">
    <div class="container-site">
      <div class="reveal max-w-content">
        <p class="eyebrow">All in one place</p>
        <h2 class="mt-2 text-h1 font-bold text-ink">Everything your team sells with, together.</h2>
        <p class="mt-3 text-ink-muted">
          Your pipeline, contacts, email, calendar, and invoices — in one app, not scattered across tabs.
        </p>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {features.map((f) => (
          <div class="reveal card">
            <div class="feature-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d={f.icon}></path>
              </svg>
            </div>
            <h3 class="text-h3 font-bold text-ink">{f.title}</h3>
            <p class="mt-1.5 text-[15px] text-ink-muted">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SPOTLIGHT 1 — email & calendar (image right) -->
  <section class="bg-white py-24 md:py-28">
    <div class="container-site grid items-center gap-12 md:grid-cols-2">
      <div class="reveal">
        <p class="eyebrow">All in one place</p>
        <h2 class="mt-2 text-h2 font-bold text-ink">Sync your email &amp; calendar.</h2>
        <p class="mt-3 text-ink-muted">
          Connect Gmail and Google Calendar and work right inside Candango — read, send, and schedule
          without switching tabs. Your conversations stay right where you need them.
        </p>
        <a href="#features" class="btn btn-ghost mt-4">See the features →</a>
      </div>
      <Carousel slides={emailSlides} class="reveal" />
    </div>
  </section>

  <!-- SPOTLIGHT 2 — QuickBooks (image left) -->
  <section class="bg-sand-cream py-24 md:py-28">
    <div class="container-site grid items-center gap-12 md:grid-cols-2">
      <Shot src="/shots/invoices.png" alt="Estimates and invoices on a deal, synced with QuickBooks" tone="pine" class="reveal md:order-1" />
      <div class="reveal md:order-2">
        <p class="eyebrow">QuickBooks integration</p>
        <h2 class="mt-2 text-h2 font-bold text-ink">Sync and manage estimates &amp; invoices.</h2>
        <p class="mt-3 text-ink-muted">
          Connect QuickBooks Online to create and manage your estimates and invoices in Candango,
          neatly organized by account.
        </p>
        <a href="#pricing" class="btn btn-ghost mt-4">See pricing →</a>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="bg-white py-24 md:py-28">
    <div class="container-site">
      <div class="reveal max-w-content">
        <p class="eyebrow">A look inside</p>
        <h2 class="mt-2 text-h1 font-bold text-ink">See it in action.</h2>
        <p class="mt-3 text-ink-muted">The screens your team will live in every day.</p>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {gallery.map((g) => (
          <Shot src={g.src} alt={g.alt} class="reveal" />
        ))}
      </div>
    </div>
  </section>

  <!-- OPEN PLATFORM -->
  <section class="bg-sand-cream py-24 md:py-28">
    <div class="container-site">
      <div class="reveal max-w-content">
        <p class="eyebrow">Open platform</p>
        <h2 class="mt-2 text-h1 font-bold text-ink">Built to fit your business — and your stack.</h2>
        <p class="mt-3 text-ink-muted">
          Candango isn't a walled garden. Connect it to the tools you already use, automate with
          real-time events, and shape the data to match how your team works.
        </p>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-3">
        {openPlatform.map((f) => (
          <div class="reveal card">
            <div class="feature-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d={f.icon}></path>
              </svg>
            </div>
            <h3 class="text-h3 font-bold text-ink">{f.title}</h3>
            <p class="mt-1.5 text-[15px] text-ink-muted">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS (pine/dark band) -->
  <section class="bg-pine-900 py-24 text-white md:py-28">
    <div class="container-site">
      <div class="reveal max-w-content">
        <p class="eyebrow text-terra-300">How it works</p>
        <h2 class="mt-2 text-h1 font-bold">From first contact to closed.</h2>
        <p class="mt-3 text-pine-100">
          Candango fits the way your team already sells — just faster, and far more organized.
        </p>
      </div>
      <div class="mt-14 grid gap-x-10 gap-y-12 md:grid-cols-3">
        {steps.map((s) => (
          <div class="reveal">
            <div class="font-display text-display font-extrabold leading-none text-terra-400/80">{s.n}</div>
            <h3 class="mt-4 text-h3 font-bold text-white">{s.title}</h3>
            <p class="mt-2 text-pine-100">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="bg-sand-cream py-24 md:py-28">
    <div class="container-site">
      <div class="reveal mx-auto max-w-content text-center">
        <p class="eyebrow">Simple pricing</p>
        <h2 class="mt-2 text-h1 font-bold text-ink">One plan. Per seat. No surprises.</h2>
        <p class="mt-3 text-ink-muted">Free for 7 days. Pay only for active users.</p>
      </div>
      <div class="reveal mx-auto mt-12 max-w-md">
        <div class="rounded-card bg-white p-8 shadow-lg ring-1 ring-sand-200">
          <p class="font-mono text-eyebrow uppercase text-terra-700">Standard</p>
          <div class="mt-3 flex items-baseline gap-1.5">
            <span class="font-display text-display font-extrabold text-ink">$30</span>
            <span class="text-ink-muted">/ user / month</span>
          </div>
          <a href={`${appUrl}/signup`} class="btn btn-primary mt-6 w-full">Start free</a>
          <ul class="mt-7 space-y-3 text-[15px] text-ink-muted">
            {[
              'Visual pipeline & list views',
              'People & companies',
              'Sync email & calendar (Google)',
              'QuickBooks estimates & invoices',
              'Reports & analytics',
              'Roles & permissions',
              'API, webhooks & custom fields',
            ].map((item) => (
              <li class="flex items-start gap-2.5">
                <svg class="mt-0.5 shrink-0 text-pine-500" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="bg-white py-24 md:py-28">
    <div class="container-site mx-auto max-w-content">
      <div class="reveal">
        <p class="eyebrow">Questions</p>
        <h2 class="mt-2 text-h1 font-bold text-ink">Good to know</h2>
      </div>
      <div class="reveal mt-8 divide-y divide-sand-200 border-y border-sand-200">
        {faqs.map((f) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-[17px] font-semibold text-ink">
              {f.q}
              <span class="text-terra-600 transition group-open:rotate-45">+</span>
            </summary>
            <p class="mt-2.5 text-ink-muted">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-sand-cream pb-24">
    <div class="container-site">
      <div class="reveal overflow-hidden rounded-[28px] bg-ink px-8 py-16 text-center text-white shadow-lg md:px-16"
        style="background-image: radial-gradient(700px 240px at 50% -30%, rgba(217,85,44,.25), transparent);">
        <h2 class="mx-auto max-w-[18ch] text-h1 font-extrabold">Everything in one place. Start today.</h2>
        <p class="mx-auto mt-3 max-w-[40ch] text-sand-200">
          Set up your workspace in minutes. Free for 7 days.
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3.5">
          <a href={`${appUrl}/signup`} class="btn btn-primary">Start free</a>
          <a href="/contact" class="btn btn-on-dark">Talk to us</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>
