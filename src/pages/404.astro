---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Page not found — Candango">
  <Nav />
  <main class="bg-white">
    <div class="container-site flex min-h-[58vh] flex-col items-center justify-center py-24 text-center">
      <p class="eyebrow">404</p>
      <h1 class="mt-2 text-display font-extrabold text-ink">This page wandered off.</h1>
      <p class="mt-3 max-w-[44ch] text-ink-muted">
        The page you're looking for doesn't exist or has moved. Let's get you back on track.
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-3.5">
        <a href="/" class="btn btn-primary">Back to home</a>
        <a href="/contact" class="btn btn-secondary">Contact us</a>
      </div>
    </div>
  </main>
  <Footer />
</Base>
